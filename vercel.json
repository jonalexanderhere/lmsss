{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/src/main.ts",
      "use": "@vercel/node"
    },
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/api/src/main.ts"
    },
    {
      "src": "/_next/(.*)",
      "dest": "apps/web/_next/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "apps/web/public/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "apps/web/$1"
    }
  ]
}
