{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/src/main.ts",
      "use": "@vercel/node",
      "config": { "includeFiles": ["apps/api/src/**"] }
    },
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "apps/api/src/main.ts"
    },
    {
      "source": "/:match*",
      "destination": "apps/web/:match*"
    }
  ]
}
